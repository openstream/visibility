# Secrets
.env

# Dependencies
/vendor/

# Erhobene Daten & generierte Reports (können gross werden / enthalten Kundendaten)
/storage/raw/*
/storage/reports/*
!/storage/raw/.gitkeep
!/storage/reports/.gitkeep

# Ausnahme: openstream (Nicks eigene Domain) als ÖFFENTLICHES BEISPIEL im Repo —
# nur der Monatsreport + Charts, NICHT onboarding.md (interne Strategie). Andere
# Kunden bleiben durch /storage/reports/* oben komplett ignoriert.
!/storage/reports/openstream/
/storage/reports/openstream/*
!/storage/reports/openstream/2*.md
!/storage/reports/openstream/charts/
!/storage/reports/openstream/charts/*.svg

# DDEV
/.ddev/.dbimageBuild/
/.ddev/db_snapshots/

# Tests
/.phpunit.cache/

# IDE / OS
.DS_Store
.idea/
.vscode/
*.log

# Editor-Swap-/Backup-Dateien (können Secrets aus .env-Bearbeitung enthalten)
*.swp
*.swo
*~
